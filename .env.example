# Copy this file to .env and fill in real values before running the app.

# Port the server listens on
PORT=3000

# Secret used to sign login tokens. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Where the SQLite database file is stored
DB_PATH=./data/app.db

# The very first admin account, created automatically the first time the
# server starts (only if no users exist yet in the database).
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-password

# Standard workday length used to convert PTO days into hours
STANDARD_WORKDAY_HOURS=8
